<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        Minimal theme for a Jetpack Compose app.
        Material3 theming is handled entirely in Compose via GuardianTheme.
        Using Theme.AppCompat.DayNight.NoActionBar avoids Material Components dependency.
    -->
    <style name="Theme.Guardian" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>
</resources>